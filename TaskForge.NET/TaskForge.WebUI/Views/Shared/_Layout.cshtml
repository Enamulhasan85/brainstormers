<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8"/>
	<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
	<title>@ViewData["Title"] - TaskForge.WebUI</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/bootstrap-icons/font/bootstrap-icons.min.css">
	<link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css">
	<link rel="stylesheet" href="~/lib/select2/css/select2.css">
</head>
<body>
<header>
	<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm mb-3" aria-label="Main Navigation">
		<div class="container-fluid">
			<a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">TaskForge.NET</a>
			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
			        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav me-auto">
					<li class="nav-item">
						<a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
					</li>
					@if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Operator")))
					{
						<li class="nav-item">
							<a class="nav-link" asp-area="" asp-controller="User" asp-action="Index">Users</a>
						</li>
					}
					@if (User.Identity?.IsAuthenticated == true)
					{
						<li class="nav-item">
							<a class="nav-link" asp-area="" asp-controller="Project" asp-action="Index">Projects</a>
						</li>
					}
				</ul>

				<ul class="navbar-nav ms-auto">
					@if (User.Identity != null && User.Identity.IsAuthenticated)
					{
						<li class="nav-item dropdown me-3">
						<a class="nav-link dropdown-toggle position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
							<i class="bi bi-bell"></i>
							<span id="notificationBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">
								0
							</span>
						</a>
						<ul class="dropdown-menu dropdown-menu-end" aria-labelledby="notificationDropdown" id="notificationList">
							<li class="dropdown-header">Notifications</li>
							<li><hr class="dropdown-divider"></li>
							<li class="text-center text-muted">No new notifications</li>
						</ul>
						</li>
						<li class="nav-item dropdown">
								<a class="nav-link dropdown-toggle position-relative" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
									@User.Identity.Name
								</a>

							<ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
								<li>
									<a class="dropdown-item" asp-controller="UserProfile" asp-action="Setup">My Profile</a>
								</li>
								<li>
									<a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Email">Manage Account</a>
								</li>
								<li>
									<a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">Change Password</a>
								</li>
								<li>
									@* <a class="dropdown-item" asp-controller="ProjectInvitation" asp-action="Index">My Invitations</a> *@
										<a class="dropdown-item d-flex justify-content-between align-items-center" asp-controller="ProjectInvitation" asp-action="Index">
											My Invitations
										</a>

								</li>

								<li>
									<hr class="dropdown-divider">
								</li>
								<li>
									<form method="post" asp-area="Identity" asp-page="/Account/Logout">
										<button type="submit" class="dropdown-item">Log Out</button>
									</form>
								</li>
							</ul>
						</li>
					}
					else
					{
						<li class="nav-item">
							<a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
						</li>
					}
				</ul>
			</div>
		</div>
	</nav>
</header>

<div class="container">
	<main role="main" class="pb-3">
		@RenderBody()
	</main>
</div>

<footer class="border-top footer text-muted">
	<div class="container">
		&copy; 2025 - TaskForge.WebUI
	</div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/select2/js/select2.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>

<script>
	const connection = new signalR.HubConnectionBuilder()
		.withUrl("/notificationHub")
		.configureLogging(signalR.LogLevel.Information)
		.build();

	const list = document.getElementById('notificationList');
	const badge = document.getElementById('notificationBadge');

	function getTimeAgo(dateString) {
		const now = new Date();
		const then = new Date(dateString);
		const diff = Math.floor((now - then) / 1000); // in seconds

		if (diff < 60) return `${diff} seconds ago`;
		if (diff < 3600) return `${Math.floor(diff / 60)} minutes ago`;
		if (diff < 86400) return `${Math.floor(diff / 3600)} hours ago`;
		return `${Math.floor(diff / 86400)} days ago`;
	}

	function renderNotificationItem(notification) {
		const li = document.createElement('li');
		li.className = 'px-2';

		const timeAgo = getTimeAgo(notification.createdAt);

		// Define icons by type (using Bootstrap Icons or emojis for simplicity)
				const typeIconMap = {
			0: '<i class="bi bi-person-plus-fill text-success fs-5"></i>',      // ProjectInvitation
			1: '<i class="bi bi-check2-square text-primary fs-5"></i>',         // TaskAssigned
			default: '<i class="bi bi-bell text-secondary fs-5"></i>'
		};

		const icon = typeIconMap[notification.type] || typeIconMap.Default;
		console.log(notification);

		li.innerHTML = `
			<a class="dropdown-item rounded ${notification.isRead ? 'notification-read' : 'notification-unread'}"
				href="${notification.targetUrl}"
				data-id="${notification.id}">
				<div class="d-flex align-items-start">
					<div class="me-2">${icon}</div>
					<div class="flex-grow-1">
						<div class="fw-semibold">${notification.title}</div>
						<small class="d-block">${notification.message}</small>
						<small class="text-muted">${timeAgo}</small>
					</div>
				</div>
			</a>
		`;
		document.getElementById('notificationList').appendChild(li); // Adjust this to your list's ID
	}




	// Load existing notifications
	fetch('/Notification/GetUserNotifications')
		.then(res => res.json())
		.then(notifications => {
			list.innerHTML = '<li class="dropdown-header">Notifications</li><li><hr class="dropdown-divider"></li>';
			if (notifications.length === 0) {
				list.innerHTML += `<li class="text-center text-muted">No notifications</li>`;
			} else {
				let unreadCount = 0;
				notifications.forEach(notification => {
					if (!notification.isRead) unreadCount++;
					renderNotificationItem(notification);
				});
				if (unreadCount > 0) {
					badge.textContent = unreadCount;
					badge.classList.remove("d-none");
				}
			}
		});

	document.addEventListener('click', function (e) {
		const item = e.target.closest('.dropdown-item');
		if (item && item.hasAttribute('data-id')) {
			e.preventDefault();

			const notificationId = item.getAttribute('data-id');
			const href = item.getAttribute('href');

				fetch(`/Notification/MarkAsRead/${notificationId}`, { method: 'POST' })
				.then(() => {
					item.classList.remove('bg-light');
					item.classList.add('bg-white');

					window.location.href = href;
				})
				.catch((error) => {
					console.error('MarkAsRead failed:', error);
					window.location.href = href; 
				});
		}
	});

	// Real-time updates
	connection.on("ReceiveNotification", function (notification) {
		renderNotificationItem(notification);
		let count = parseInt(badge.textContent || "0") + 1;
		badge.textContent = count;
		badge.classList.remove("d-none");
	});

	connection.start().then(() => {
		console.log("SignalR Connected");
	}).catch(err => console.error(err));
</script>

<style>
	/* Unread notification styling */
	.notification-unread {
		background-color: #e8f0ff !important;
		color: #202124 !important;
		font-weight: 600;
		border-left: 4px solid #0a66c2;
		padding-left: 1rem;
	}

	/* Read notification styling */
	.notification-read {
		background-color: #ffffff !important;
		color: #4b4f56 !important;
		font-weight: 400;
	}

	/* Hover effect for any notification */
	.dropdown-item:hover {
		background-color: #d2e3fc !important;
	}
</style>



@await RenderSectionAsync("Scripts", false)
</body>
</html>