# Example Environment Variables for TaskForge.NET E2E Tests
# Copy this file to .env and update with your actual values

# Application URLs
BASE_URL=http://localhost:5283
API_URL=http://localhost:5283

# Test User Credentials
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=Password123!

# Admin Credentials
ADMIN_EMAIL=admin@taskforge.com
ADMIN_PASSWORD=Admin123!

# Operator Credentials
OPERATOR_EMAIL=operator@taskforge.com
OPERATOR_PASSWORD=Operator123!

# Test Configuration
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
DEFAULT_COMMAND_TIMEOUT=10000
REQUEST_TIMEOUT=10000
RESPONSE_TIMEOUT=10000
PAGE_LOAD_TIMEOUT=60000

# Feature Flags
ENABLE_EMAIL_TESTS=false
ENABLE_VISUAL_TESTS=false
ENABLE_VIDEO_RECORDING=true
ENABLE_SCREENSHOTS=true

# Retry Configuration
RETRY_RUN_MODE=2
RETRY_OPEN_MODE=0
